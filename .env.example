# Backend
FLASK_APP=app.py
FLASK_ENV=production
DATABASE_URL=sqlite:///../database/pass_network.db

# SECURITY: Generate a strong random secret key
# Use: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_STRONG_SECRET_KEY_FROM_SECRETS_TOKEN_HEX_32

# Optional: API key for lightweight authentication
# If set, all API endpoints (except health) require X-API-Key header
# Use: python -c "import secrets; print(secrets.token_hex(16))"
TACTIX_API_KEY=

# Frontend
# Local Vite development uses the /api proxy in frontend/vite.config.ts.
# If the frontend is deployed separately, create frontend/.env and set:
# VITE_API_BASE_URL=https://your-backend.example.com/api
